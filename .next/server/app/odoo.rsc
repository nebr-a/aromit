pe":"FAQPage","@id":"https://www.arom.ch/odoo#faq","mainEntity":[{"@type":"Question","name":"Combien coûte une implémentation Odoo pour une PME en Suisse ?","acceptedAnswer":{"@type":"Answer","text":"Chez AROM IT, trois forfaits : Odoo Starter à 4'900 CHF (3 modules, 4 semaines), Odoo Business à 9'900 CHF (6 modules, 6-8 semaines), Odoo Enterprise dès 19'900 CHF (sur mesure, 3-4 mois). La licence Odoo est facturée séparément par Odoo SA."}},{"@type":"Question","name":"La licence Odoo est-elle incluse dans vos forfaits ?","acceptedAnswer":{"@type":"Answer","text":"Non, la licence Odoo est facturée en sus par Odoo SA. Trois plans existent : Odoo Community (gratuit, open source), Odoo Standard (~24 CHF/utilisateur/mois, 1 app), Odoo Custom (~37 CHF/utilisateur/mois, apps illimitées + développements). Nous vous conseillons le plan optimal lors de l'audit gratuit."}},{"@type":"Question","name":"Combien de temps prend une intégration Odoo ?","acceptedAnswer":{"@type":"Answer","text":"Entre 4 semaines (Starter) et 3-4 mois (Enterprise). La moyenne pour une PME classique est de 6-8 semaines avec le forfait Business."}},{"@type":"Question","name":"Où sont hébergées les données Odoo ?","acceptedAnswer":{"@type":"Answer","text":"Nous hébergeons votre instance Odoo dans notre datacenter privé à Montreux, en Suisse. Vos données ne sortent pas du pays."}},{"@type":"Question","name":"Quels modules Odoo couvrez-vous ?","acceptedAnswer":{"@type":"Answer","text":"Ventes, CRM, Comptabilité, Stock, RH, Marketing, E-commerce, Production, Achats, Facturation, Projets, Maintenance, etc. Odoo compte plus de 40 modules natifs, nous activons uniquement ceux dont vous avez besoin."}}]}]}9:T16ed,{"@context":"https://schema.org","@graph":[{"@type":["LocalBusiness","ProfessionalService","Organization"],"@id":"https://www.arom.ch/#business","name":"AROM IT & Cloud Services","alternateName":["AROM IT","AROM Cloud"],"url":"https://www.arom.ch","logo":{"@type":"ImageObject","url":"https://www.arom.c